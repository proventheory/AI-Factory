# Control Plane API (required for Console to fetch data).
# On Vercel: set this to the SAME Render (or other) URL as your live control-plane web service.
# Staging example: https://ai-factory-api-staging.onrender.com
# Production example: https://ai-factory-api-prod.onrender.com
# After changing this, redeploy the Console so the new URL is baked into the client bundle
# (NEXT_PUBLIC_* is inlined at build time — set it for Production and for Preview if you use preview deploys).
# If you see "Vercel could not reach your Control Plane URL (proxy/rewrite to Render failed)":
#   - Open https://YOUR-API-HOST/health in a browser (wake Render if it spun down).
#   - In Vercel → Settings → Environment Variables: set NEXT_PUBLIC_CONTROL_PLANE_API to the API origin only
#     (https://….onrender.com) with no trailing slash and no /v1 path.
# Optional: CONTROL_PLANE_PROXY_URL — same URL, server-only; used by app/api/control-plane/* when the
# runtime proxy runs (helps if you ever split build-time vs server upstream).
# Control Plane must have CORS_ORIGIN including your Vercel origin (comma-separated if multiple).
# For Shopify custom apps (shpat_): control-plane must be on a build that exposes
# capabilities.shopify_brand_admin_token on GET /health (redeploy from main) and must set SHOPIFY_CONNECTOR_ENCRYPTION_KEY.
NEXT_PUBLIC_CONTROL_PLANE_API=http://localhost:3001

# Supabase (optional but recommended for brand asset uploads)
# When set: Brand Identity edit page can upload assets to Supabase Storage (bucket "upload", path brands/{id}/assets/).
# Run migration supabase/migrations/20250306140000_upload_bucket_and_policies.sql so the upload bucket and RLS policies exist.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Email Design Generator (optional — when set to a public URL, /email-design-generator is proxied there).
# On Vercel: leave unset so the Console serves /email-design-generator (Edit, campaigns list, etc.); localhost causes 404 DNS_HOSTNAME_RESOLVED_PRIVATE.
# NEXT_PUBLIC_EMAIL_MARKETING_ORIGIN=http://localhost:3002

# Control Plane API (required for Console to fetch data).
# On Vercel: set this to your deployed Control Plane URL (e.g. https://ai-factory-api-prod.onrender.com)
# and ensure the Control Plane has CORS_ORIGIN set to your Vercel origin, or you'll see connection errors.
NEXT_PUBLIC_CONTROL_PLANE_API=http://localhost:3001

# Supabase (optional but recommended for brand asset uploads)
# When set: Brand Identity edit page can upload assets to Supabase Storage (bucket "upload", path brands/{id}/assets/).
# Run migration supabase/migrations/20250306140000_upload_bucket_and_policies.sql so the upload bucket and RLS policies exist.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Email Marketing Factory (optional — when set to a public URL, /email-marketing is proxied there).
# On Vercel: leave unset so the Console serves /email-marketing (Edit, campaigns list, etc.); localhost causes 404 DNS_HOSTNAME_RESOLVED_PRIVATE.
# NEXT_PUBLIC_EMAIL_MARKETING_ORIGIN=http://localhost:3002

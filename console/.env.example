# Control Plane API (required for Console to fetch data).
# On Vercel: set this to your deployed Control Plane URL (e.g. https://ai-factory-api-prod.onrender.com)
# and ensure the Control Plane has CORS_ORIGIN set to your Vercel origin, or you'll see connection errors.
NEXT_PUBLIC_CONTROL_PLANE_API=http://localhost:3001

# Supabase Auth (optional — when set, use createSupabaseBrowserClient() for session/RBAC)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Email Marketing Factory (optional — when set, /email-marketing is proxied to this origin; app runs with basePath /email-marketing)
# NEXT_PUBLIC_EMAIL_MARKETING_ORIGIN=http://localhost:3002

# Control-plane image: exclude heavy or irrelevant paths
.git
.github
node_modules
dist
.next
*.md
.env
.env.*
!.env.example
console
email-marketing-factory
evals
scripts
# Control-plane image needs run-migrate.mjs at runtime
!scripts/run-migrate.mjs
!scripts/sql-migrations.manifest.json
*.test.ts
*.spec.ts
__tests__
.cursor
*.log
.DS_Store

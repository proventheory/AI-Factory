{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolvePackageJsonImports": false,
    "paths": {
      "#control-plane/*": ["./control-plane/src/*"],
      "#runners/*": ["./runners/src/*"],
      "#adapters/*": ["./adapters/src/*"]
    }
  },
  "include": [
    "control-plane/src/**/*",
    "runners/src/**/*",
    "adapters/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}

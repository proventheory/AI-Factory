# AI Factory — Environment Variables (example)
# Copy to .env and fill in values. Never commit .env.
# See docs/OPERATIONS_RUNBOOK.md for full env checklist and Render self-heal setup.

# -- Terraform (infra/) — only needed when running terraform plan/apply --
# VERCEL_API_TOKEN=...
# SUPABASE_ACCESS_TOKEN=...

# -- Render (Control Plane) — for Render MCP in Cursor; paste same key into ~/.cursor/mcp.json —
# RENDER_API_KEY=...

# -- Database (Supabase / Neon) --
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
# For Neon: use the pooled URL (host ending with -pooler) and keep pool small to avoid "MaxClientsInSessionMode" / "max clients reached".
# DATABASE_POOL_MAX=5   # Control Plane default 5, Runner default 3. Increase only if DB allows (e.g. larger Neon compute).
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -- Control Plane --
PORT=3001
CORS_ORIGIN=*

# Control Plane: Email Marketing wizard (Pexels search + self-hosted campaign/logo images)
PEXELS_API_KEY=your-pexels-api-key
# Copy images to CDN (upload bucket). Use same project as Control Plane DB: staging anqhihkvovuhfzsyqtxu, prod wxupyzthtzeckgbzqmjy. Settings → API → service_role.
SUPABASE_URL=https://anqhihkvovuhfzsyqtxu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -- Runner → Control Plane (Dev Kernel V1: job failures sent to POST /v1/job_failures) —
# CONTROL_PLANE_URL=http://localhost:3001   # Runner: Control Plane base URL (default same if unset)

# -- Console --
NEXT_PUBLIC_CONTROL_PLANE_API=http://localhost:3001

# -- LLM Gateway (runner + control plane; load from repo root: npm run dev:runner) --
# Use an OpenAI-compatible endpoint (e.g. LiteLLM proxy at 4000, or https://api.openai.com/v1 with OPENAI_API_KEY).
LLM_GATEWAY_URL=http://localhost:4000
OPENAI_API_KEY=sk-...                 # For OpenAI or gateway that forwards to OpenAI
ANTHROPIC_API_KEY=sk-ant-...          # Optional (for MAX tier claude models)

# -- Gateway: Redis Cache (Phase 3) --
REDIS_URL=redis://localhost:6379      # Required for response caching

# -- Observability (see docs/LLM_GATEWAY_AND_OPTIMIZATION.md) --
# Sentry: errors in Control Plane, Runner, and Console. Set in Vercel/Render env and repo root for runners.
SENTRY_DSN=https://...@sentry.io/...   # Optional; when set, errors are reported to Sentry
# Console (Next.js) can use same SENTRY_DSN or NEXT_PUBLIC_SENTRY_DSN for client-side errors

# Langfuse: LLM traces. Configure in LiteLLM gateway (gateway config) or set here for future runner traces.
LANGFUSE_SECRET_KEY=sk-lf-...        # Optional
LANGFUSE_PUBLIC_KEY=pk-lf-...        # Optional
NEXT_PUBLIC_LANGFUSE_URL=https://cloud.langfuse.com  # Optional link in Console

# -- Evals (Phase 4) --
PROMPTFOO_THRESHOLD=0.90             # Pass rate for CI

# -- MCP Servers (Phase 5 MCP) --
# JSON array or use config/mcp.json file instead
# MCP_SERVERS_JSON='[{"name":"github","server_type":"http","url_or_cmd":"https://..."}]'

# -- Feature toggles (see docs/ENABLEMENT_ENV_VARS.md) --
# ENABLE_SELF_HEAL=true                 # Control Plane: enable self-heal (no-artifacts scan, Render remediate). Needs RENDER_API_KEY.
# ENABLE_AUTO_REPAIR=true               # Control Plane: Dev Kernel V1 — 5-min loop to repair failed runs (subgraph_replay when policy allows).
# OPTIMIZER_APPLY=true                  # When running optimizer script: apply suggestions to DB (default: dry-run)
# NEXT_PUBLIC_FEATURE_WEBHOOK_OUTBOX=false   # Console: set to "false" to hide Webhook Outbox nav item (default: visible)

# -- Optimizer (Phase 5) --
CONTROL_PLANE_API=http://localhost:3001

# -- SEO: Connect Google (GSC/GA4 OAuth). Control Plane only. See docs/SEO_GOOGLE_OAUTH_SETUP.md —
# GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
# GOOGLE_OAUTH_ENCRYPTION_KEY=<32-byte hex, e.g. from: openssl rand -hex 32>
# CONTROL_PLANE_URL=https://ai-factory-api-staging.onrender.com   # or http://localhost:3001
# CONSOLE_URL=https://your-console.vercel.app   # OAuth error redirect (avoids callback redirect loop)

# -- Shopify connector (brand-level). Control Plane only. Encrypts client_secret at rest. —
# SHOPIFY_CONNECTOR_ENCRYPTION_KEY=<32-byte hex, e.g. from: openssl rand -hex 32>

# -- Airtable (scripts/airtable-discovery.mjs, multi-source import plan) —
# Personal access token from Airtable: Account → Developer hub → Personal access tokens. Never commit the real value.
AIRTABLE_TOKEN=pat...
# Optional: target base ID for discovery (default used by script if unset)
# AIRTABLE_BASE_ID=app...

# -- Email templates: seed (scripts/seed-email-templates.mjs) and Cultura sync (scripts/sync-email-templates-from-cultura.mjs) —
# CULTURA_SUPABASE_URL=https://your-project.supabase.co
# CULTURA_SUPABASE_ANON=your-publishable-key

# AI Factory — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# -- Terraform (infra/) — only needed when running terraform plan/apply --
# VERCEL_API_TOKEN=...
# SUPABASE_ACCESS_TOKEN=...

# -- Render (Control Plane) — for Render MCP in Cursor; paste same key into ~/.cursor/mcp.json —
# RENDER_API_KEY=...

# -- Database (Supabase) --
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -- Control Plane --
PORT=3001
CORS_ORIGIN=*

# -- Console --
NEXT_PUBLIC_CONTROL_PLANE_API=http://localhost:3001

# -- LLM Gateway (runner + control plane; load from repo root: npm run dev:runner) --
# Use an OpenAI-compatible endpoint (e.g. LiteLLM proxy at 4000, or https://api.openai.com/v1 with OPENAI_API_KEY).
LLM_GATEWAY_URL=http://localhost:4000
OPENAI_API_KEY=sk-...                 # For OpenAI or gateway that forwards to OpenAI
ANTHROPIC_API_KEY=sk-ant-...          # Optional (for MAX tier claude models)

# -- Gateway: Redis Cache (Phase 3) --
REDIS_URL=redis://localhost:6379      # Required for response caching

# -- Observability (see docs/LLM_GATEWAY_AND_OPTIMIZATION.md) --
# Sentry: errors in Control Plane, Runner, and Console. Set in Vercel/Render env and repo root for runners.
SENTRY_DSN=https://...@sentry.io/...   # Optional; when set, errors are reported to Sentry
# Console (Next.js) can use same SENTRY_DSN or NEXT_PUBLIC_SENTRY_DSN for client-side errors

# Langfuse: LLM traces. Configure in LiteLLM gateway (gateway config) or set here for future runner traces.
LANGFUSE_SECRET_KEY=sk-lf-...        # Optional
LANGFUSE_PUBLIC_KEY=pk-lf-...        # Optional
NEXT_PUBLIC_LANGFUSE_URL=https://cloud.langfuse.com  # Optional link in Console

# -- Evals (Phase 4) --
PROMPTFOO_THRESHOLD=0.90             # Pass rate for CI

# -- MCP Servers (Phase 5 MCP) --
# JSON array or use config/mcp.json file instead
# MCP_SERVERS_JSON='[{"name":"github","server_type":"http","url_or_cmd":"https://..."}]'

# -- Feature toggles (see docs/ENABLEMENT_ENV_VARS.md) --
# ENABLE_SELF_HEAL=true                 # Control Plane: enable self-heal (no-artifacts scan, Render remediate). Needs RENDER_API_KEY.
# OPTIMIZER_APPLY=true                  # When running optimizer script: apply suggestions to DB (default: dry-run)
# NEXT_PUBLIC_FEATURE_WEBHOOK_OUTBOX=false   # Console: set to "false" to hide Webhook Outbox nav item (default: visible)

# -- Optimizer (Phase 5) --
CONTROL_PLANE_API=http://localhost:3001

# Build and run Runner worker from repo root (shares DB with Control Plane).
# Render: type: worker, dockerContext: ., dockerfilePath: ./Dockerfile.runner
# Set DATABASE_URL, CONTROL_PLANE_URL, LLM_GATEWAY_URL in Render Dashboard.

FROM node:20-alpine AS builder
WORKDIR /app
RUN echo "Runner: build started"
COPY package.json package-lock.json ./
RUN echo "Runner: npm ci..." && npm ci --no-optional --no-audit
COPY . .
RUN echo "Runner: esbuild..." && mkdir -p dist && NODE_OPTIONS="--max-old-space-size=2048" npx esbuild runners/src/index.ts \
  --bundle --platform=node --target=node20 --format=cjs \
  --outfile=dist/runner-bundle.js --sourcemap \
  --external:pg --external:uuid --external:mjml

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY package.json package-lock.json ./
RUN npm ci --omit=dev
RUN npm pkg set type=commonjs
COPY --from=builder /app/dist ./dist
CMD ["node", "dist/runner-bundle.js"]

{
  "name": "ai-factory",
  "version": "0.1.0",
  "private": true,
  "description": "AI Factory: autonomous orchestration system for dev and marketing pipelines",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "prestart:control-plane": "npm run build",
    "start:control-plane": "node dist/control-plane/src/index.js",
    "dev:control-plane": "npx tsx control-plane/src/index.ts",
    "start:runner": "node dist/runners/src/index.js",
    "dev:runner": "npx tsx runners/src/index.ts",
    "db:migrate": "node --env-file=.env scripts/run-migrate.mjs",
    "db:migrate:console": "node scripts/one-time-migrate-for-console.mjs",
    "db:migrate:new": "node scripts/run-migrate-supabase-only.mjs",
    "db:migrate:pipeline-v2": "node --env-file=.env scripts/run-pipeline-v2-migrate.mjs",
    "db:migrate:dev-kernel": "node --env-file=.env scripts/run-dev-kernel-migrate.mjs",
    "db:migrate:ads-commerce": "node --env-file=.env scripts/run-ads-commerce-migrate.mjs",
    "test:pipeline-v2-api": "node scripts/test-pipeline-v2-api.mjs",
    "test:dev-kernel-api": "node scripts/test-dev-kernel-api.mjs",
    "test:taxonomy-catalog-api": "node scripts/test-taxonomy-catalog-api.mjs",
    "verify:taxonomy-db": "node --env-file=.env scripts/verify-taxonomy-db.mjs",
    "verify:migrations": "node scripts/verify-migrations-registered.mjs",
    "verify:migration-names": "node scripts/validate-migration-names.mjs",
    "lint": "tsc --noEmit",
    "test": "npx tsx --test runners/tests/*.test.ts scripts/*.test.ts",
    "test:runners": "npx tsx --test runners/tests/*.test.ts",
    "test:optimizer": "npx tsx --test scripts/optimizer.test.ts",
    "optimizer": "npx tsx scripts/optimizer.ts",
    "doctor": "bash scripts/doctor.sh",
    "doctor:json": "bash scripts/doctor.sh --json",
    "baseline": "npx tsx scripts/baseline.ts",
    "self-heal": "npx tsx scripts/self-heal.ts",
    "self-heal:dry": "npx tsx scripts/self-heal.ts --dry-run",
    "self-heal:tsc": "npx tsx scripts/self-heal.ts --step tsc",
    "self-heal:verbose": "npx tsx scripts/self-heal.ts --verbose",
    "self-heal:openhands": "npx tsx scripts/self-heal.ts --agent openhands",
    "self-heal:swe": "npx tsx scripts/self-heal.ts --agent swe-agent",
    "graph:audit": "npx tsx scripts/graph/audit.ts",
    "graph:repair-plan": "npx tsx scripts/graph/repair-plan.ts",
    "graph:lineage": "npx tsx scripts/graph/lineage.ts",
    "graph:replay": "npx tsx scripts/graph/replay.ts",
    "migration:guard": "npx tsx scripts/migration/guard.ts",
    "post-migration:audit": "npx tsx scripts/migration/post-audit.ts",
    "debug:bundle": "npx tsx scripts/debug/bundle.ts",
    "doctor:run": "npx tsx scripts/debug/run-doctor.ts",
    "preview-landing": "npx tsx scripts/preview-landing.ts",
    "seed:brand-sticky-green": "node scripts/seed-brand-sticky-green.mjs",
    "seed:email-component-library": "node scripts/seed-email-component-library.mjs",
    "seed:sticky-green-composed": "node scripts/seed-sticky-green-composed-template.mjs",
    "seed:email-templates": "node scripts/seed-email-templates.mjs",
    "test:stitch-sticky-green": "node scripts/test-stitch-email-sticky-green.mjs",
    "update:stitch-template": "node scripts/update-stitch-template-mjml.mjs",
    "airtable:discovery": "node scripts/airtable-discovery.mjs",
    "airtable:import": "node scripts/airtable-import.mjs",
    "airtable:import:pharmacy": "node --env-file=.env scripts/airtable-import-pharmacy.mjs",
    "airtable:import:first-capital": "node --env-file=.env scripts/airtable-import-first-capital.mjs",
    "woocommerce:sync:pharmacy": "node --env-file=.env scripts/woocommerce-sync-pharmacy.mjs"
  },
  "dependencies": {
    "@sentry/node": "^8.55.0",
    "@supabase/supabase-js": "^2.98.0",
    "axios": "^1.8.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^9.15.1",
    "googleapis": "^144.0.0",
    "handlebars": "^4.7.8",
    "mjml": "^4.18.0",
    "pg": "^8.13.1",
    "uuid": "^11.1.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mjml": "^4.7.4",
    "@types/node": "^22.13.0",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "dotenv": "^16.6.1",
    "esbuild": "^0.24.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
